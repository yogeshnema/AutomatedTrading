DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=automated_trading
DATABASE_USER=trading_owner
DATABASE_PASSWORD=
DATABASE_APPLICATION_NAME=AutomatedTrading
DATABASE_CONNECT_TIMEOUT=5
DATABASE_SSLMODE=prefer

# Kite credentials stay on the backend. KITE_ACCESS_TOKEN is refreshed after
# the daily Kite login flow; never expose these values through VITE_* variables.
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
MARKET_DATA_SERVICE_HOST=0.0.0.0
MARKET_DATA_SERVICE_PORT=8201
MARKET_DATA_POLL_SECONDS=60
MARKET_DATA_CORS_ORIGIN=http://localhost:5173
RISK_SERVICE_HOST=0.0.0.0
RISK_SERVICE_PORT=8081
RISK_SERVICE_THREADS=4
TZ=Asia/Kolkata
