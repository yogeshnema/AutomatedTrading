digraph G {
  graph [bgcolor="#111827", pad="0.45", rankdir=LR, nodesep="0.7", ranksep="0.7", fontname="Arial", label="PERSISTENCE AND CACHE", labelloc=t, fontcolor="#e5e7eb", fontsize=24];
  node [shape=box, style="rounded,filled", fillcolor="#1f2937", color="#38bdf8", fontcolor="#f3f4f6", fontname="Arial", fontsize=15, margin="0.24,0.18"];
  edge [color="#94a3b8", fontcolor="#cbd5e1", fontname="Arial", fontsize=11, arrowsize=0.75];
  svc [label="Pricing · Risk · Strategy\nlong-running services", fillcolor="#172554"];
  cache [label="REDIS\nfast and temporary\nquotes · job status · expensive results", shape=cylinder, color="#fb7185", fillcolor="#3f1d2e"];
  db [label="POSTGRESQL\ndurable and auditable\ntrades · curves · snapshots · results", shape=cylinder, color="#fbbf24", fillcolor="#3f2f0d"];
  svc -> cache [dir=both, label="read-through cache / TTL"];
  cache -> db [label="cache miss"];
  db -> svc [label="authoritative data"];
  svc -> db [label="results + audit"];
}
